@model QL_NhaHangCafe_Nhom07.Models.DatBan

<h2 class="mb-4">Đặt bàn</h2>

<form asp-action="Create">

    <div asp-validation-summary="All"
         class="text-danger mb-3">
    </div>

    <div class="mb-3">

        <label class="form-label">
            Khách hàng
        </label>

        <select asp-for="MaKh"
                class="form-select"
                asp-items="ViewBag.MaKh">

            <option value="">
                -- Chọn khách hàng --
            </option>

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Bàn
        </label>

        <select asp-for="MaBan"
                class="form-select"
                asp-items="ViewBag.MaBan">

            <option value="">
                -- Chọn bàn --
            </option>

        </select>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Số lượng khách
        </label>

        <input asp-for="SoLuongKhach"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label class="form-label">
            Thời gian đặt
        </label>

        <input asp-for="ThoiGianDat"
               type="date"
               class="form-control" />  

    </div>

    <div class="mb-3">

        <label class="form-label">
            Ghi chú
        </label>

        <textarea asp-for="GhiChu"
                  class="form-control">
        </textarea>

    </div>

    <button type="submit"
            class="btn btn-success">

        Đặt bàn

    </button>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}