@model QL_NhaHangCafe_Nhom07.Models.DatBan

@{
    ViewData["Title"] = "Chi tiết đặt bàn";
}

<h2 class="mb-4">Chi tiết đặt bàn</h2>

<div class="card shadow p-4">

    <dl class="row">

        <dt class="col-sm-3">
            Khách hàng
        </dt>

        <dd class="col-sm-9">
            @Model.MaKhNavigation?.HoTen
        </dd>

        <dt class="col-sm-3">
            Bàn
        </dt>

        <dd class="col-sm-9">
            @Model.MaBanNavigation?.TenBan
        </dd>

        <dt class="col-sm-3">
            Số lượng khách
        </dt>

        <dd class="col-sm-9">
            @Model.SoLuongKhach
        </dd>

        <dt class="col-sm-3">
            Thời gian đặt
        </dt>

        <dd class="col-sm-9">
            @(Model.ThoiGianDat.ToString("dd/MM/yyyy HH:mm"))
        </dd>

        <dt class="col-sm-3">
            Ghi chú
        </dt>

        <dd class="col-sm-9">
            @Model.GhiChu
        </dd>

        <dt class="col-sm-3">
            Trạng thái
        </dt>

        <dd class="col-sm-9">
            @Model.TrangThai
        </dd>

        <dt class="col-sm-3">
            Ngày tạo
        </dt>

        <dd class="col-sm-9">
            @(Model.NgayTao?.ToString("dd/MM/yyyy"))
        </dd>

    </dl>

</div>

<div class="mt-3">

    <a asp-action="Edit"
       asp-route-id="@Model?.MaDatBan"
       class="btn btn-warning">

        Sửa

    </a>

    <a asp-action="Index"
       class="btn btn-secondary">

        Quay lại

    </a>

</div>