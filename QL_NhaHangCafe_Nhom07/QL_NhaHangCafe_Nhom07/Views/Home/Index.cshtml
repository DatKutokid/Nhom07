@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="text-center p-5 rounded shadow-lg" style="background: rgba(0, 0, 0, 0.65); backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.1); max-width: 700px;">

        <div class="mb-4 text-warning">
            <i class="bi bi-cup-hot" style="font-size: 4rem;"></i>
        </div>

        <h1 class="display-4 fw-bold text-white mb-3" style="letter-spacing: 2px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
            PhongRestaurant
        </h1>

        <p class="lead text-white-50 mb-4" style="font-size: 1.25rem;">
            Nơi kết tinh hương vị tinh hoa ẩm thực cùng không gian thưởng thức ấm cúng, sang trọng. Khám phá thực đơn phong phú và đặt bàn ngay hôm nay để nhận ưu đãi tốt nhất.
        </p>

        <hr class="my-4 border-secondary opacity-25">

        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-4">
            <a asp-controller="MonAns" asp-action="Index" class="btn btn-outline-light btn-lg px-4 gap-3 fw-bold">
                <i class="bi bi-book-half me-2"></i>Xem Thực Đơn
            </a>
            <a asp-controller="DatBans" asp-action="Create" class="btn btn-warning btn-lg px-4 fw-bold text-dark shadow-sm">
                <i class="bi bi-calendar-check-fill me-2"></i>Đặt Bàn Trước
            </a>
        </div>

        <div class="mt-4">
            <a asp-controller="Bans" asp-action="Index" class="text-white-50 text-decoration-none small hover-underline">
                <i class="bi bi-grid-3x3-gap me-1"></i> Truy cập nhanh sơ đồ & trạng thái bàn hiện tại
            </a>
        </div>

    </div>
</div>
             
<style>
    /* Hiệu ứng rê chuột nhẹ nhàng cho đường dẫn sơ đồ bàn */
    .hover-underline:hover {
        color: #ffc107 !important;
        text-decoration: underline !important;
        transition: color 0.2s ease-in-out;
    }
</style>