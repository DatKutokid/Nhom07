@model QL_NhaHangCafe_Nhom07.Models.HoaDon

@{
    ViewData["Title"] = "Chi tiết hóa đơn #" + Model.MaHd;
}

<div class="inner-content-box">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold mb-0">
            <i class="bi bi-receipt-cutoff me-2"></i>
            Chi tiết hóa đơn

            <span class="badge bg-dark ms-2">
                #@Model.MaHd
            </span>
        </h2>

        <a asp-action="Index"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left me-1"></i>
            Quay lại

        </a>

    </div>

    <!-- THÔNG TIN -->
    <div class="row g-4 mb-4">

        <!-- THÔNG TIN HÓA ĐƠN -->
        <div class="col-lg-6">

            <div class="card shadow-sm h-100">

                <div class="card-header bg-dark text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Thông tin hóa đơn
                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-borderless mb-0">

                        <tbody>

                            <tr>
                                <td width="40%" class="fw-semibold text-muted">
                                    Mã hóa đơn
                                </td>

                                <td class="fw-bold">
                                    #@Model.MaHd
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold text-muted">
                                    Ngày lập
                                </td>

                                <td>
                                    @(Model.NgayLap?.ToString("dd/MM/yyyy HH:mm")
                                                                        ?? "Không có")
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold text-muted">
                                    Bàn
                                </td>

                                <td>
                                    @(Model.MaBanNavigation?.TenBan
                                                                        ?? "Không có")
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold text-muted">
                                    Nhân viên
                                </td>

                                <td>
                                    @(Model.MaNvNavigation?.HoTen
                                                                        ?? "Không có")
                                </td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- THÔNG TIN KHÁCH -->
        <div class="col-lg-6">

            <div class="card shadow-sm h-100">

                <div class="card-header bg-dark text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i>
                        Thông tin khách hàng
                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-borderless mb-0">

                        <tbody>

                            <tr>
                                <td width="40%" class="fw-semibold text-muted">
                                    Họ tên
                                </td>

                                <td>
                                    @(Model.MaKhNavigation?.HoTen
                                                                        ?? "Khách lẻ")
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold text-muted">
                                    Số điện thoại
                                </td>

                                <td>
                                    @(Model.MaKhNavigation?.SoDienThoai
                                                                        ?? "Không có")
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold text-muted">
                                    Email
                                </td>

                                <td>
                                    @(Model.MaKhNavigation?.Email
                                                                        ?? "Không có")
                                </td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <!-- DANH SÁCH MÓN -->
    <div class="card shadow-sm mb-4">

        <div class="card-header bg-dark text-white">

            <h5 class="mb-0">
                <i class="bi bi-basket2-fill me-2"></i>
                Danh sách món ăn
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-dark text-center">

                        <tr>

                            <th width="70">STT</th>

                            <th>Tên món</th>

                            <th width="180">Đơn giá</th>

                            <th width="120">Số lượng</th>

                            <th width="220">Thành tiền</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.ChiTietHoaDons != null &&
                                                Model.ChiTietHoaDons.Any())
                        {
                            int stt = 1;

                            @foreach (var ct in Model.ChiTietHoaDons)
                            {
                                var gia = ct.MaMonNavigation?.Gia ?? 0;
                                var sl = ct.SoLuong;
                                var thanhTien = gia * sl;

                                <tr>

                                    <td class="text-center">
                                        @stt
                                    </td>

                                    <td>
                                        @(ct.MaMonNavigation?.TenMon
                                                                        ?? "Không có")
                                    </td>

                                    <td class="text-end">

                                        @gia.ToString("N0") ₫

                                    </td>

                                    <td class="text-center">

                                        @sl

                                    </td>

                                    <td class="text-end fw-bold text-danger">

                                        @thanhTien.ToString("N0") ₫

                                    </td>

                                </tr>

                                stt++;
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5"
                                    class="text-center text-muted py-4">

                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>

                                    Chưa có món ăn nào

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- TỔNG TIỀN -->
    <div class="d-flex justify-content-end mb-4">

        <div class="card shadow-sm px-4 py-3"
             style="min-width:300px; border-left:5px solid #6F4E37;">

            <div class="text-muted mb-1">
                Tổng thanh toán
            </div>

            <div class="fs-3 fw-bold text-danger text-end">

                @(Model.TongTien?.ToString("N0") ?? "0") ₫

            </div>

        </div>

    </div>

    <!-- BUTTON -->
    <div class="d-flex gap-2">

        <a asp-action="Index"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left me-1"></i>
            Danh sách

        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.MaHd"
           class="btn btn-danger"
           onclick="return confirm('Bạn có chắc muốn xóa hóa đơn này?')">

            <i class="bi bi-trash-fill me-1"></i>
            Xóa hóa đơn

        </a>

        <button onclick="window.print()"
                class="btn btn-dark ms-auto">

            <i class="bi bi-printer-fill me-1"></i>
            In hóa đơn

        </button>

    </div>

</div>

@section Styles {

    <style>

        @@media print {

            .navbar,
            .footer,
            .btn {
                display: none !important;
            }

            body {
                background: white !important;
            }

            .inner-content-box {
                box-shadow: none !important;
                background: white !important;
                padding: 0 !important;
            }
        }

    </style>

}