@model QL_NhaHangCafe_Nhom07.Models.HoaDon

<h2>Chi tiết hóa đơn</h2>

<div class="card p-3">

    <h5>Bàn: @Model.MaBan</h5>

    <h5>Ngày lập: @Model.NgayLap</h5>

    <table class="table table-bordered mt-3">

        <thead class="table-dark">
            <tr>
                <th>Món ăn</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.ChiTietHoaDons)
            {
                <tr>

                    <td>@item.MaMon</td>

                    <td>@item.SoLuong</td>

                    <td>
                        @item.DonGia.ToString("N0")
                    </td>

                    <td>
                        @((item.SoLuong * item.DonGia).ToString("N0"))
                    </td>

                </tr>
            }

        </tbody>

    </table>

    <h4 class="text-end">
        Tổng tiền:
        @Model.TongTien.ToString() VNĐ
    </h4>

</div>